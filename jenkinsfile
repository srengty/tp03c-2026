pipeline {
    agent {
      label 'ubuntu'
    }

    environment {
        CHAT_ID = '538826222'
    }

    stages {
        stage('Build') {
            steps {
                // Get some code from a GitHub repository
                // git 'https://github.com/srengty/tp03c-2026.git'
                checkout scm

                // Run Composer on a Unix agent.
                sh "composer install"

                // To run Composer on a Windows agent, use
                // bat "composer install"

                sh "npm install"

                // copy .env.example to .env
                sh "cp .env.example .env"

                // change database connection settings in .env
                // sh "sed -i 's/DB_HOST=localhost/DB_HOST=mysql/' .env"
                // sh "sed -i 's/DB_DATABASE=homestead/DB_DATABASE=tp03c/' .env"

                // generate application key
                sh "php artisan key:generate"

                sh "php artisan migrate --force"

                // Run the tests with PHPUnit.
                sh "php artisan test"
            }

            post {
                // If Composer was able to run the tests, even if some of the test
                // failed, record the test results and archive the jar file.
                success {
                    // mail bcc: '', body: 'Build no. $BUILD_NUMBER', cc: '', from: '', replyTo: '', subject: 'build success', to: 'srengty@gmail.com'
                    // send using plugin http request to telegram bot api to send message to telegram channel (bot token has id i42026bot)
                    // httpRequest httpMode: 'POST', url: 'https://api.telegram.org/bot8624504079:AAH81aI4O-HESsXfVrsrjmKyRO2aGom7goM/sendMessage?chat_id=538826222&text=build%20success%20no.%20$BUILD_NUMBER'
                    script {
                        def msg = "build success no. ${env.BUILD_NUMBER}\\n${env.BUILD_URL}"

                        withCredentials([string(credentialsId: 'i420226bot', variable: 'TOKEN')]) {
                            def res = httpRequest(
                                url: "https://api.telegram.org/bot${TOKEN}/sendMessage",
                                httpMode: 'POST',
                                contentType: 'APPLICATION_FORM',
                                requestBody: "chat_id=${CHAT_ID}&text=${msg}",
                                validResponseCodes: '100:599'
                            )

                            echo "Status: ${res.status}"
                            echo "Response: ${res.content}"
                        }
                    }
                }
                failure {
                    // mail bcc: '', body: 'Build no. $BUILD_NUMBER', cc: '', from: '', replyTo: '', subject: 'build failed', to: 'srengty@gmail.com'
                    script {
                        def msg = "build failed no. ${env.BUILD_NUMBER}\\n${env.BUILD_URL}"

                        withCredentials([string(credentialsId: 'i420226bot', variable: 'TOKEN')]) {
                            httpRequest(
                                url: "https://api.telegram.org/bot${TOKEN}/sendMessage",
                                httpMode: 'POST',
                                contentType: 'APPLICATION_FORM',
                                requestBody: "chat_id=${CHAT_ID}&text=${msg}"
                            )
                        }
                    }
                }
            }
        }
    }
}
